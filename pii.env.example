# Local Configuration
# Copy this file to pii.env and fill in your actual values.
# pii.env is not tracked by git (see .gitignore).

DECK_IP=192.168.1.x
DECK_USER=deck
DECK_PASSWORD=your_deck_password
DECK_SUDO_PASSWORD=your_deck_password
HOST_SUDO_PASSWORD=your_host_sudo_password
HOST_BT_MAC=XX:XX:XX:XX:XX:XX
DECK_BT_MAC_PUBLIC=XX:XX:XX:XX:XX:XX
